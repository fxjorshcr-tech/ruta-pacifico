# Resend — https://resend.com/api-keys
# IMPORTANT: rotate the key if it was ever shared anywhere public.
RESEND_API_KEY=re_your_api_key_here

# Sender shown to customers. Must use a domain verified in Resend
# (rutapacifico.com — already DKIM/SPF verified).
EMAIL_FROM="Ruta Pacifico <reservations@rutapacifico.com>"

# Where new bookings + contact form messages are delivered.
# Comma-separated. Add reservations@rutapacifico.com once the mailbox exists.
EMAIL_NOTIFICATIONS_TO=reservations@rutapacifico.com,fxjorshcr@gmail.com

# Optional: address customers see when they hit "reply" on auto-emails.
# Defaults to the first EMAIL_NOTIFICATIONS_TO entry.
EMAIL_REPLY_TO=reservations@rutapacifico.com

# Google Analytics 4 — Measurement ID from
# Admin → Data Streams → Web. Looks like "G-XXXXXXXXXX".
# Leave empty to disable analytics (no scripts will load).
NEXT_PUBLIC_GA_ID=

# Google Search Console — verification code (HTML tag method).
# In Search Console → Add property → URL prefix → "HTML tag",
# copy ONLY the value of the content="..." attribute here.
# Leave empty to skip the meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
